# Copy this file to .env and fill in your values.
#
# .env is git-ignored. NEVER commit a real key.

# Anthropic API key for AI Insights tab.
# Get one at https://console.anthropic.com/
# If unset, the AI Insights tab degrades gracefully and shows a placeholder.
ANTHROPIC_API_KEY=

# Path to the DuckDB warehouse file populated by `dbt build`.
# Default assumes the dashboard runs from the app/ folder.
DUCKDB_PATH=../warehouse.duckdb

# Claude model to use. Default is sonnet-4.6 (fast, cheap, smart enough for
# narrative summarization). Switch to opus-4-7 for deeper reasoning.
ANTHROPIC_MODEL=claude-sonnet-4-6
